# Copy to .env.local and fill in. Never commit .env.local.

# Supabase (set once a project exists)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps Platform
# Server key: restricted by enabled API (Geocoding, Address Validation, Routes)
GOOGLE_MAPS_SERVER_KEY=
# Browser key: restricted by HTTP referrer (Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
