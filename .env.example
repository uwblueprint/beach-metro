# Copy to .env.local and fill in. Never commit .env.local.

# Supabase
# Publishable key (sb_publishable_...) is safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret key (sb_secret_...) is server-only and bypasses RLS. Never expose it.
SUPABASE_SECRET_KEY=
# Postgres connection string (Dashboard -> Connect -> Session pooler URI).
# Used by `pnpm db:push` / `db:seed` / `db:types` — never by the app at runtime.
SUPABASE_DB_URL=

# Dedicated admin for the automated API smoke suite (`pnpm smoke`).
# Create it with: pnpm create-admin <email> <password>
SMOKE_ADMIN_EMAIL=
SMOKE_ADMIN_PASSWORD=

# Google Maps Platform
# Server key: restricted by enabled API (Geocoding, Address Validation, Routes)
GOOGLE_MAPS_SERVER_KEY=
# Browser key: restricted by HTTP referrer (Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# Shared secret for the Vercel Cron coordinate refresh (/api/cron/refresh-coords).
# Set the same value in Vercel project env; Vercel sends it as a Bearer token.
CRON_SECRET=
